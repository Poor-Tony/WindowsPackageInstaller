{
  "Meta": {
    "Description": "Windows Setup Configuration for LTSC & Pro (Slimmed)",
    "Version": "1.1.0"
  },
  "System": {
    "RebootIfRequired": false,
    "LoggingEnabled": true,
    "LogFilePath": "C:\\Windows\\Temp\\WindowsSetupUtility.log"
  },
  "Bootstrap": {
    "InstallWinget": true,
    "InstallWindowsTerminal": true,
    "InstallPowerShell7": true
  },
  "Packages": {
    "Winget": {
      "Enable": true,
      "InstallList": [
        "Mozilla.Firefox",
        "7zip.7zip",
        "Notepad++.Notepad++",
        "Microsoft.VisualStudioCode",
        "ZedIndustries.Zed",
        "JanDeDobbeleer.OhMyPosh",
        "Git.Git",
        "ONLYOFFICE.DesktopEditors"
      ]
    },
    "CustomInstallers": []
  }
}
