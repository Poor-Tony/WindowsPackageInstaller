{
  "Meta": {
    "Description": "Windows Setup Configuration for LTSC & Pro (Chocolatey Version)",
    "Version": "1.2.0"
  },
  "System": {
    "RebootIfRequired": false,
    "LoggingEnabled": true,
    "LogFilePath": "C:\\Windows\\Temp\\WindowsSetupUtility.log"
  },
  "Bootstrap": {
    "InstallChocolatey": true,
    "InstallWindowsTerminal": true,
    "InstallPowerShell7": true
  },
  "Packages": {
    "InstallList": [
      "firefox",
      "7zip",
      "notepadplusplus",
      "vscode",
      "zed",
      "oh-my-posh",
      "git",
      "onlyoffice"
    ],
    "CustomInstallers": [
      {
        "Name": "btop",
        "Url": "https://github.com/aristocratos/btop4win/releases/latest/download/btop4win-LHM-x64.zip",
        "Destination": "C:\\Program Files\\btop",
        "AddToPath": true
      }
    ],
    "NerdFonts": [
      "CascadiaCode",
      "CascadiaMono",
      "FiraCode",
      "Inconsolata",
      "JetBrainsMono",
      "Noto",
      "SourceCodePro",
      "UbuntuMono",
      "ZedMono"
    ]
  }
}
